  - m_Id: 4119208194093056
    m_Localized: INDIETRO
    m_Metadata:
      m_Items: []
  - m_Id: 4824198197948416
    m_Localized: "Spendi monete per costruire pi\xF9 torri!"
    m_Metadata:
      m_Items: []
  - m_Id: 4824198227308544
    m_Localized: Fai attenzione al raggio d'attacco.
    m_Metadata:
      m_Items: []
  - m_Id: 4824198227308545
    m_Localized: Piazza le torri vicino ai percorsi nemici!
    m_Metadata:
      m_Items: []
  - m_Id: 4824198227308546
    m_Localized: "A volte potenziare \xE8 meglio che costruire."
    m_Metadata:
      m_Items: []
  - m_Id: 4824198227308547
    m_Localized: Nemici diversi richiedono torri diverse.
    m_Metadata:
      m_Items: []
  - m_Id: 4824198227308548
    m_Localized: Piazza le torri ad alto danno in punti strategici.
    m_Metadata:
      m_Items: []
  - m_Id: 4824198227308549
    m_Localized: Osserva il percorso nemico prima di costruire.
    m_Metadata:
      m_Items: []
  - m_Id: 4824198227308550
    m_Localized: Non conservare monete. Trasformale in potenza di fuoco!
    m_Metadata:
      m_Items: []
  - m_Id: 4826130945814528
    m_Localized: GAME OVER
    m_Metadata:
      m_Items: []
  - m_Id: 4826727535226880
    m_Localized: MENU PRINCIPALE
    m_Metadata:
      m_Items: []
  - m_Id: 4826727535226881
    m_Localized: RIPROVA
    m_Metadata:
      m_Items: []
  - m_Id: 5063535741251584
    m_Localized: 'Nemici uccisi :'
    m_Metadata:
      m_Items: []
  - m_Id: 5063535779000320
    m_Localized: 'PV :'
    m_Metadata:
      m_Items: []
  - m_Id: 5066098880425984
    m_Localized: VITTORIA
    m_Metadata:
      m_Items: []
  - m_Id: 5066098905591808
    m_Localized: LIVELLO SUCCESSIVO
    m_Metadata:
      m_Items: []
  - m_Id: 5096780902051840
    m_Localized: FINE
    m_Metadata:
      m_Items: []
  - m_Id: 5096780935606272
    m_Localized: "Grazie per aver giocato!\\nQuesto gioco \xE8 stato creato con passione,\\ne
      il tuo viaggio significa molto per me.\\nAlla prossima avventura!"
    m_Metadata:
      m_Items: []
  - m_Id: 5183481720745984
    m_Localized: SVILUPPATO DA
    m_Metadata:
      m_Items: []
  - m_Id: 5452975861018624
    m_Localized: 1. PROTEGGI IL TEMPIO
    m_Metadata:
      m_Items: []
  - m_Id: 5452975886184448
    m_Localized: 'Ferma i nemici prima che raggiungano il Tempio.

      Se i tuoi
      PV scendono a 0, perdi.'
    m_Metadata:
      m_Items: []
  - m_Id: 5452975886184449
    m_Localized: 2. COSTRUISCI UNA TORRE
    m_Metadata:
      m_Items: []
  - m_Id: 5452975886184450
    m_Localized: Tocca una casella di costruzione. Scegli una torre e premi Compra.
    m_Metadata:
      m_Items: []
  - m_Id: 5452975886184451
    m_Localized: 3. POTENZIA UNA TORRE
    m_Metadata:
      m_Items: []
  - m_Id: 5452975886184452
    m_Localized: 'Seleziona una torre piazzata.

      Premi Potenzia per migliorarne
      le statistiche.'
    m_Metadata:
      m_Items: []

    m_Metadata:
      m_Items: []
  - m_Id: 5066098880425984
    m_Localized: "\u041F\u041E\u0411\u0415\u0414\u0410"
    m_Metadata:
      m_Items: []
  - m_Id: 5066098905591808
    m_Localized: "\u0421\u041B\u0415\u0414\u0423\u042E\u0429\u0418\u0419 \u0423\u0420\u041E\u0412\u0415\u041D\u042C"
    m_Metadata:
      m_Items: []
  - m_Id: 5096780902051840
    m_Localized: "\u041A\u041E\u041D\u0415\u0426"
    m_Metadata:
      m_Items: []
  - m_Id: 5096780935606272
    m_Localized: "\u0421\u043F\u0430\u0441\u0438\u0431\u043E \u0437\u0430 \u0438\u0433\u0440\u0443!\\n\u042D\u0442\u0430
      \u0438\u0433\u0440\u0430 \u0441\u043E\u0437\u0434\u0430\u043D\u0430 \u0441
      \u0431\u0435\u0441\u043A\u043E\u043D\u0435\u0447\u043D\u043E\u0439 \u0441\u0442\u0440\u0430\u0441\u0442\u044C\u044E,\\n\u0438
      \u0432\u0430\u0448\u0435 \u043F\u0443\u0442\u0435\u0448\u0435\u0441\u0442\u0432\u0438\u0435
      \u0437\u043D\u0430\u0447\u0438\u0442 \u0434\u043B\u044F \u043C\u0435\u043D\u044F
      \u0432\u0441\u0451.\\n\u0414\u043E \u0432\u0441\u0442\u0440\u0435\u0447\u0438
      \u0432 \u0441\u043B\u0435\u0434\u0443\u044E\u0449\u0435\u043C \u043F\u0440\u0438\u043A\u043B\u044E\u0447\u0435\u043D\u0438\u0438!"
    m_Metadata:
      m_Items: []
  - m_Id: 5183481720745984
    m_Localized: "\u0420\u0410\u0417\u0420\u0410\u0411\u041E\u0422\u0427\u0418\u041A\u0418"
    m_Metadata:
      m_Items: []
  - m_Id: 5452975861018624
    m_Localized: "1. \u0417\u0410\u0429\u0418\u0429\u0410\u0419\u0422\u0415 \u0425\u0420\u0410\u041C"
    m_Metadata:
      m_Items: []
  - m_Id: 5452975886184448
    m_Localized: "\u041E\u0441\u0442\u0430\u043D\u043E\u0432\u0438\u0442\u0435 \u0432\u0440\u0430\u0433\u043E\u0432
      \u0434\u043E \u0442\u043E\u0433\u043E, \u043A\u0430\u043A \u043E\u043D\u0438
      \u0434\u043E\u0441\u0442\u0438\u0433\u043D\u0443\u0442 \u0425\u0440\u0430\u043C\u0430.\n\u0415\u0441\u043B\u0438
      \u0432\u0430\u0448\u0435 \u0437\u0434\u043E\u0440\u043E\u0432\u044C\u0435 \u0443\u043F\u0430\u0434\u0435\u0442
      \u0434\u043E 0, \u0432\u044B \u043F\u0440\u043E\u0438\u0433\u0440\u0430\u0435\u0442\u0435."
    m_Metadata:
      m_Items: []
  - m_Id: 5452975886184449
    m_Localized: "2. \u041F\u041E\u0421\u0422\u0420\u041E\u0419\u0422\u0415 \u0411\u0410\u0428\u041D\u042E"
    m_Metadata:
      m_Items: []
  - m_Id: 5452975886184450
    m_Localized: "\u041D\u0430\u0436\u043C\u0438\u0442\u0435 \u043D\u0430 \u043A\u043B\u0435\u0442\u043A\u0443
      \u0434\u043B\u044F \u043F\u043E\u0441\u0442\u0440\u043E\u0439\u043A\u0438.
      \u0412\u044B\u0431\u0435\u0440\u0438\u0442\u0435 \u0431\u0430\u0448\u043D\u044E
      \u0438 \u043D\u0430\u0436\u043C\u0438\u0442\u0435 \u041A\u0443\u043F\u0438\u0442\u044C."
    m_Metadata:
      m_Items: []
  - m_Id: 5452975886184451
    m_Localized: "3. \u0423\u041B\u0423\u0427\u0428\u0418\u0422\u0415 \u0411\u0410\u0428\u041D\u042E"
    m_Metadata:
      m_Items: []
  - m_Id: 5452975886184452
    m_Localized: "\u0412\u044B\u0431\u0435\u0440\u0438\u0442\u0435 \u043F\u043E\u0441\u0442\u0440\u043E\u0435\u043D\u043D\u0443\u044E
      \u0431\u0430\u0448\u043D\u044E.\n\u041D\u0430\u0436\u043C\u0438\u0442\u0435
      \u0423\u043B\u0443\u0447\u0448\u0438\u0442\u044C, \u0447\u0442\u043E\u0431\u044B
      \u043F\u043E\u0432\u044B\u0441\u0438\u0442\u044C \u0435\u0451 \u0445\u0430\u0440\u0430\u043A\u0442\u0435\u0440\u0438\u0441\u0442\u0438\u043A\u0438."
    m_Metadata:
      m_Items: []
  - m_Id: 5826887677521920

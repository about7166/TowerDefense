  - m_Id: 3691231803224064
    m_Localized: VOLUME
    m_Metadata:
      m_Items: []
  - m_Id: 3691231803224065
    m_Localized: EFFETS SONORES
    m_Metadata:
      m_Items: []
  - m_Id: 3691231803224066
    m_Localized: MUSIQUE
    m_Metadata:
      m_Items: []
  - m_Id: 3694718142263296
    m_Localized: "CAM\xC9RA"
    m_Metadata:
      m_Items: []
  - m_Id: 3694718142263297
    m_Localized: LANGUE
    m_Metadata:
      m_Items: []
  - m_Id: 4118756152979456
    m_Localized: "VIT. CAM\xC9RA - WASD"
    m_Metadata:
      m_Items: []
  - m_Id: 4118756178145280
    m_Localized: "VIT. CAM\xC9RA - SOURIS"
    m_Metadata:
      m_Items: []
  - m_Id: 4119208194093056
    m_Localized: RETOUR
    m_Metadata:
      m_Items: []
  - m_Id: 4824198197948416
    m_Localized: "D\xE9pensez des pi\xE8ces pour construire des tours !"
    m_Metadata:
      m_Items: []
  - m_Id: 4824198227308544
    m_Localized: "Faites attention \xE0 la port\xE9e d'attaque."
    m_Metadata:
      m_Items: []
  - m_Id: 4824198227308545
    m_Localized: "Placez des tours pr\xE8s des chemins ennemis !"
    m_Metadata:
      m_Items: []
  - m_Id: 4824198227308546
    m_Localized: "Parfois, am\xE9liorer vaut mieux que construire."
    m_Metadata:
      m_Items: []
  - m_Id: 4824198227308547
    m_Localized: "Diff\xE9rents ennemis n\xE9cessitent diff\xE9rentes tours."
    m_Metadata:
      m_Items: []
  - m_Id: 4824198227308548
    m_Localized: "Placez les tours \xE0 gros d\xE9g\xE2ts aux endroits strat\xE9giques."
    m_Metadata:
      m_Items: []
  - m_Id: 4824198227308549
    m_Localized: Observez la route ennemie avant de construire.
    m_Metadata:
      m_Items: []
  - m_Id: 4824198227308550
    m_Localized: "Ne gardez pas vos pi\xE8ces. Transformez-les en puissance de feu
      !"
    m_Metadata:
      m_Items: []
  - m_Id: 4826130945814528
    m_Localized: "PARTIE TERMIN\xC9E"
    m_Metadata:
      m_Items: []
  - m_Id: 4826727535226880
    m_Localized: MENU PRINCIPAL
    m_Metadata:
      m_Items: []
  - m_Id: 4826727535226881
    m_Localized: "R\xC9ESSAYER"
    m_Metadata:
      m_Items: []
  - m_Id: 5063535741251584
    m_Localized: "Ennemis tu\xE9s :"
    m_Metadata:
      m_Items: []
  - m_Id: 5063535779000320
    m_Localized: 'PV :'
    m_Metadata:
      m_Items: []
  - m_Id: 5066098880425984
    m_Localized: VICTOIRE
    m_Metadata:
      m_Items: []
  - m_Id: 5066098905591808
    m_Localized: NIVEAU SUIVANT
    m_Metadata:
      m_Items: []
  - m_Id: 5096780902051840
    m_Localized: FIN
    m_Metadata:
      m_Items: []
  - m_Id: 5096780935606272
    m_Localized: "Merci d'avoir jou\xE9 !\\nCe jeu a \xE9t\xE9 cr\xE9\xE9 avec passion,\\net
      votre voyage compte beaucoup pour moi.\\n\xC0 la prochaine aventure !"
    m_Metadata:
      m_Items: []
  - m_Id: 5183481720745984
    m_Localized: "D\xC9VELOPP\xC9 PAR"
    m_Metadata:
      m_Items: []
  - m_Id: 5452975861018624
    m_Localized: "1. PROT\xC9GEZ LE TEMPLE"
    m_Metadata:
      m_Items: []
  - m_Id: 5452975886184448
    m_Localized: "Arr\xEAtez les ennemis avant qu'ils n'atteignent le Temple.\nSi
      vos PV tombent \xE0 0, vous perdez."
    m_Metadata:
      m_Items: []
  - m_Id: 5452975886184449
    m_Localized: 2. CONSTRUISEZ UNE TOUR
    m_Metadata:
      m_Items: []
  - m_Id: 5452975886184450
    m_Localized: Touchez une case de construction. Choisissez une tour et appuyez
      sur Acheter.
    m_Metadata:
      m_Items: []
  - m_Id: 5452975886184451
    m_Localized: "3. AM\xC9LIOREZ UNE TOUR"
    m_Metadata:
      m_Items: []
  - m_Id: 5452975886184452
    m_Localized: "S\xE9lectionnez une tour plac\xE9e.\nAppuyez sur Am\xE9liorer pour
      augmenter ses stats."
    m_Metadata:
      m_Items: []
  references:

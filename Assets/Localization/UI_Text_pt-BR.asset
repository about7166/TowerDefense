  - m_Id: 1135449668726784
    m_Localized: TUTORIAL
    m_Metadata:
      m_Items: []
  - m_Id: 1135449668726785
    m_Localized: "CR\xC9DITOS"
    m_Metadata:
      m_Items: []
  - m_Id: 1135449672921088
    m_Localized: SAIR
    m_Metadata:
      m_Items: []
  - m_Id: 3691231773863936
    m_Localized: "CONFIGURA\xC7\xD5ES"
    m_Metadata:
      m_Items: []
  - m_Id: 3691231803224064
    m_Localized: VOLUME
    m_Metadata:
      m_Items: []
  - m_Id: 3691231803224065
    m_Localized: EFEITOS SONOROS
    m_Metadata:
      m_Items: []
  - m_Id: 3691231803224066
    m_Localized: "M\xDASICA DE FUNDO"
    m_Metadata:
      m_Items: []
  - m_Id: 3694718142263296
    m_Localized: "C\xC2MERA"
    m_Metadata:
      m_Items: []
  - m_Id: 3694718142263297
    m_Localized: IDIOMA
    m_Metadata:
      m_Items: []
  - m_Id: 4118756152979456
    m_Localized: "VEL. C\xC2MERA - WASD"
    m_Metadata:
      m_Items: []
  - m_Id: 4118756178145280
    m_Localized: "VEL. C\xC2MERA - MOUSE"
    m_Metadata:
      m_Items: []
  - m_Id: 4119208194093056
    m_Localized: VOLTAR
    m_Metadata:
      m_Items: []
  - m_Id: 4824198197948416
    m_Localized: Gaste moedas para construir mais torres!
    m_Metadata:
      m_Items: []
  - m_Id: 4824198227308544
    m_Localized: "Preste aten\xE7\xE3o ao alcance das torres."
    m_Metadata:
      m_Items: []
  - m_Id: 4824198227308545
    m_Localized: Coloque torres perto do caminho dos inimigos!
    m_Metadata:
      m_Items: []
  - m_Id: 4824198227308546
    m_Localized: "\xC0s vezes, melhorar \xE9 melhor do que construir."
    m_Metadata:
      m_Items: []
  - m_Id: 4824198227308547
    m_Localized: Inimigos diferentes exigem torres diferentes.
    m_Metadata:
      m_Items: []
  - m_Id: 4824198227308548
    m_Localized: "Coloque torres de alto dano em posi\xE7\xF5es estrat\xE9gicas."
    m_Metadata:
      m_Items: []
  - m_Id: 4824198227308549
    m_Localized: Observe a rota inimiga antes de construir.
    m_Metadata:
      m_Items: []
  - m_Id: 4824198227308550
    m_Localized: "N\xE3o guarde moedas. Transforme-as em poder de fogo!"
    m_Metadata:
      m_Items: []
  - m_Id: 4826130945814528
    m_Localized: FIM DE JOGO
    m_Metadata:
      m_Items: []
  - m_Id: 4826727535226880
    m_Localized: MENU PRINCIPAL
    m_Metadata:
      m_Items: []
  - m_Id: 4826727535226881
    m_Localized: TENTAR NOVAMENTE
    m_Metadata:
      m_Items: []
  - m_Id: 5063535741251584
    m_Localized: 'Inimigos mortos :'
    m_Metadata:
      m_Items: []
  - m_Id: 5063535779000320
    m_Localized: 'HP :'
    m_Metadata:
      m_Items: []
  - m_Id: 5066098880425984
    m_Localized: "VIT\xD3RIA"
    m_Metadata:
      m_Items: []
  - m_Id: 5066098905591808
    m_Localized: "PR\xD3XIMO N\xCDVEL"
    m_Metadata:
      m_Items: []
  - m_Id: 5096780902051840
    m_Localized: FIM
    m_Metadata:
      m_Items: []
  - m_Id: 5096780935606272
    m_Localized: "Muito obrigado por jogar!\\nEste jogo foi feito com muita paix\xE3o,\\ne
      sua jornada significa tudo para mim.\\nEspero te ver na pr\xF3xima aventura!"
    m_Metadata:
      m_Items: []
  - m_Id: 5183481720745984
    m_Localized: DESENVOLVIDO POR
    m_Metadata:
      m_Items: []
  - m_Id: 5452975861018624
    m_Localized: 1. PROTEJA O TEMPLO
    m_Metadata:
      m_Items: []
  - m_Id: 5452975886184448
    m_Localized: "Pare os inimigos antes que alcancem o Templo.\nSe seu HP chegar
      a 0, voc\xEA perde."
    m_Metadata:
      m_Items: []
  - m_Id: 5452975886184449
    m_Localized: 2. CONSTRUA UMA TORRE
    m_Metadata:
      m_Items: []
  - m_Id: 5452975886184450
    m_Localized: "Toque em um espa\xE7o de constru\xE7\xE3o. Escolha uma torre e
      pressione Comprar."
    m_Metadata:
      m_Items: []
  - m_Id: 5452975886184451
    m_Localized: 3. MELHORE UMA TORRE
    m_Metadata:
      m_Items: []
  - m_Id: 5452975886184452
    m_Localized: "Selecione uma torre constru\xEDda.\nPressione Melhorar para aumentar
      seus atributos."
    m_Metadata:
      m_Items: []
  - m_Id: 5826887677521920
    m_Localized: PAUSA
    m_Metadata:
      m_Items: []
  - m_Id: 5826887702687744
    m_Localized: RETOMAR
    m_Metadata:
      m_Items: []

    m_Metadata:
      m_Items: []
  - m_Id: 5096780902051840
    m_Localized: THE END
    m_Metadata:
      m_Items: []
  - m_Id: 5096780935606272
    m_Localized: "Thank you so much for playing! \nThis game was made with endless
      passion, \nand your journey through it means the world to me. \nHope to see
      you in the next adventure!"
    m_Metadata:
      m_Items: []
  - m_Id: 5183481720745984
    m_Localized: CREDITS BY
    m_Metadata:
      m_Items: []
  - m_Id: 5452975861018624
    m_Localized: 1. PROTECT THE TEMPLE
    m_Metadata:
      m_Items: []
  - m_Id: 5452975886184448
    m_Localized: Stop enemies before they reach the Temple.\nIf your HP reaches 0,
      you lose.
    m_Metadata:
      m_Items: []
  - m_Id: 5452975886184449
    m_Localized: 2. BUILD A TOWER
    m_Metadata:
      m_Items: []
  - m_Id: 5452975886184450
    m_Localized: Tap a build tile.Choose a tower and press Buy.
    m_Metadata:
      m_Items: []
  - m_Id: 5452975886184451
    m_Localized: 3. UPGRADE A TOWER
    m_Metadata:
      m_Items: []
  - m_Id: 5452975886184452
    m_Localized: Select a placed tower.\nPress Upgrade to improve its stats.
    m_Metadata:
      m_Items: []
